<idea-plugin url="https://github.com/DragonKnightOfBreeze/Paradox-Language-Support" xmlns:xi="http://www.w3.org/2001/XInclude">
  <category>Languages</category>

  <!-- But please be patient, for ... -->
  <id>icu.windea.pls</id>

  <!-- With the title of breeze, the dragon knight embarks on her Journey to seek in the wonderful world. -->
  <vendor email="dk_breeze@qq.com" url="https://github.com/DragonKnightOfBreeze">DragonKnightOfBreeze</vendor>

  <resource-bundle>messages.ChronicleBundle</resource-bundle>

  <!-- Dependencies of the guide book -->
  <depends>com.intellij.modules.lang</depends>
  <depends>com.intellij.platform.images</depends>
  <depends optional="true" config-file="chronicle-extension-json.xml">com.intellij.modules.json</depends>
  <depends optional="true" config-file="chronicle-extension-markdown.xml">org.intellij.plugins.markdown</depends>
  <depends optional="true" config-file="chronicle-extension-diagram.xml">com.intellij.diagram</depends>
  <depends optional="true" config-file="chronicle-extension-translation.xml">cn.yiiguxing.plugin.translate</depends>

  <!-- Chapters of the guide book -->
  <xi:include href="/META-INF/chronicle-inject.xml" xpointer="xpointer(/idea-plugin/*)"/> <!-- Chapter of the injection magic needs to be put at the very front -->
  <xi:include href="/META-INF/chronicle-base.xml" xpointer="xpointer(/idea-plugin/*)"/>
  <xi:include href="/META-INF/chronicle-ide.xml" xpointer="xpointer(/idea-plugin/*)"/>
  <xi:include href="/META-INF/chronicle-cwt.xml" xpointer="xpointer(/idea-plugin/*)"/>
  <xi:include href="/META-INF/chronicle-script.xml" xpointer="xpointer(/idea-plugin/*)"/>
  <xi:include href="/META-INF/chronicle-localisation.xml" xpointer="xpointer(/idea-plugin/*)"/>
  <xi:include href="/META-INF/chronicle-csv.xml" xpointer="xpointer(/idea-plugin/*)"/>
  <xi:include href="/META-INF/chronicle-images.xml" xpointer="xpointer(/idea-plugin/*)"/>
  <xi:include href="/META-INF/chronicle-config.xml" xpointer="xpointer(/idea-plugin/*)"/>
  <xi:include href="/META-INF/chronicle-lang.xml" xpointer="xpointer(/idea-plugin/*)"/>
  <xi:include href="/META-INF/chronicle-intentions.xml" xpointer="xpointer(/idea-plugin/*)"/>
  <xi:include href="/META-INF/chronicle-inspections.xml" xpointer="xpointer(/idea-plugin/*)"/>
  <xi:include href="/META-INF/chronicle-integrations.xml" xpointer="xpointer(/idea-plugin/*)"/>
  <xi:include href="/META-INF/chronicle-extensions.xml" xpointer="xpointer(/idea-plugin/*)"/>
  <xi:include href="/META-INF/chronicle-ai.xml" xpointer="xpointer(/idea-plugin/*)"/>
  <xi:include href="/META-INF/chronicle-tools.xml" xpointer="xpointer(/idea-plugin/*)"/>
  <xi:include href="/META-INF/chronicle-ep.xml" xpointer="xpointer(/idea-plugin/*)"/> <!-- Chapter of the extension point magic is put at the end -->
</idea-plugin>
