<idea-plugin>
  <extensions defaultExtensionNs="com.intellij">
    <notificationGroup id="pls" displayType="BALLOON" isLogByDefault="true" key="notificationGroup"/>
    <notificationGroup id="pls.settings" displayType="BALLOON" isLogByDefault="true" key="notificationGroup.settings"/>
    <notificationGroup id="pls.diff" displayType="BALLOON" isLogByDefault="true" key="notificationGroup.diff"/>
    <notificationGroup id="pls.manipulation" displayType="BALLOON" isLogByDefault="true" key="notificationGroup.manipulation"/>

    <webHelpProvider implementation="icu.windea.pls.ide.help.PlsHelpProvider"/>
    <postStartupActivity implementation="icu.windea.pls.ide.PlsLifecycleListener"/>
    <iconMapper mappingFile="PlsIconMappings.json"/>
  </extensions>

  <applicationListeners>
    <listener class="icu.windea.pls.ide.PlsLifecycleListener" topic="com.intellij.ide.AppLifecycleListener"/>
    <listener class="icu.windea.pls.ide.settings.PlsSettingsMigrator" topic="com.intellij.ide.AppLifecycleListener"/>
  </applicationListeners>
</idea-plugin>
